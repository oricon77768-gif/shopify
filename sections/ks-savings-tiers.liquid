{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="ks-savings-tiers page-width section-{{ section.id }}-padding">
    <div class="ks-savings-tiers__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="ks-savings-tiers__heading inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <div class="ks-savings-tiers__subheading rte">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <ul class="ks-savings-tiers__grid" role="list">
        {%- for block in section.blocks -%}
          <li class="ks-savings-tiers__item" {{ block.shopify_attributes }}>
            {%- if block.settings.threshold != blank -%}
              <span class="ks-savings-tiers__threshold">{{ block.settings.threshold | escape }}</span>
            {%- endif -%}

            {%- if block.settings.label != blank -%}
              <span class="ks-savings-tiers__label">{{ block.settings.label | escape }}</span>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .ks-savings-tiers {
    display: grid;
    gap: 2rem;
  }

  .ks-savings-tiers__header {
    max-width: 72rem;
  }

  .ks-savings-tiers__heading {
    margin: 0;
  }

  .ks-savings-tiers__subheading {
    margin-top: 0.8rem;
    color: rgba(var(--color-foreground), 0.75);
  }

  .ks-savings-tiers__subheading > * {
    margin-top: 0;
    margin-bottom: 0;
  }

  .ks-savings-tiers__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ks-savings-tiers__item {
    display: grid;
    align-content: start;
    gap: 0.35rem;
    min-height: 8.8rem;
    padding: 1.4rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.14);
    border-radius: var(--text-boxes-radius);
    background: rgb(var(--color-background));
  }

  .ks-savings-tiers__threshold {
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1.2;
    color: rgb(var(--color-foreground));
  }

  .ks-savings-tiers__label {
    font-size: 1.3rem;
    line-height: 1.35;
    color: rgba(var(--color-foreground), 0.7);
  }

  @media screen and (min-width: 750px) {
    .ks-savings-tiers {
      gap: 2.4rem;
    }

    .ks-savings-tiers__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Savings tiers",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Stock up and save more",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "default": "<p>Build a bigger Korean beauty basket and unlock savings according to your current store promotions.</p>",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Tier",
      "settings": [
        {
          "type": "text",
          "id": "threshold",
          "default": "$100+",
          "label": "Threshold"
        },
        {
          "type": "text",
          "id": "label",
          "default": "Entry savings tier",
          "label": "Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Savings tiers",
      "blocks": [
        {
          "type": "tier",
          "settings": {
            "threshold": "$100+",
            "label": "Start saving on beauty essentials"
          }
        },
        {
          "type": "tier",
          "settings": {
            "threshold": "$250+",
            "label": "Better value for stock-up orders"
          }
        },
        {
          "type": "tier",
          "settings": {
            "threshold": "$500+",
            "label": "Unlock higher campaign savings"
          }
        },
        {
          "type": "tier",
          "settings": {
            "threshold": "$1,000+",
            "label": "Best tier for group and bulk baskets"
          }
        }
      ]
    }
  ]
}
{% endschema %}
